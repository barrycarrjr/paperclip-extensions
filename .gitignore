# Per-machine / per-developer overrides
.env
.env.local
.env.*
*.local
# Local-only scripts / configs (e.g. add-user-mapping.local.ts) — by
# convention any path with a `.local.` infix is operator-specific and
# must not be committed.
*.local.*

# Credential / key material — should never be tracked
*.pem
*.key
credentials.json
service-account*.json
secrets/
.secrets/

# OS junk
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.iml

# Build artifacts (skills shouldn't have these but just in case)
node_modules/
dist/
build/
dist-pcplugins/

# Local smoke-test scripts (not part of the published plugins)
.smoke-tests/
