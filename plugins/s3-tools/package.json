{
  "name": "paperclip-plugin-s3-tools",
  "version": "0.1.0",
  "description": "Paperclip plugin that exposes S3 download, upload, sync, and list operations as agent tools. Multi-bucket, per-bucket company isolation, credential-gated. Supports AWS S3 and S3-compatible services (MinIO, R2, Spaces).",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "pnpm": { "onlyBuiltDependencies": ["esbuild", "sharp"] }, "dependencies": {
    "@paperclipai/plugin-sdk": "^2026.427.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "esbuild": "^0.27.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "author": "BookZeta"
}
