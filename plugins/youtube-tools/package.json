{
  "name": "paperclip-plugin-youtube-tools",
  "version": "0.1.0",
  "description": "Paperclip plugin that exposes YouTube upload, metadata update, thumbnail, and playlist operations as agent tools. Uses YouTube Data API v3 with OAuth2 refresh token authentication.",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "^2026.427.0",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "esbuild": "^0.27.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "author": "BookZeta"
}
