{
  "name": "paperclip-plugin-backup-tools",
  "version": "0.1.8",
  "description": "Paperclip plugin that produces encrypted system snapshots of an instance's data on a schedule (or on demand) and ships them to one or more destinations (S3-compatible, Google Drive). Restore wizard included. Encryption is client-side (Argon2id + AES-256-GCM); destinations never see plaintext.",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@noble/ciphers": "^1.0.0",
    "@noble/hashes": "^1.5.0",
    "@paperclipai/plugin-sdk": "^2026.427.0",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "esbuild": "^0.27.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "author": "Barry Carr & Tony Allard"
}
