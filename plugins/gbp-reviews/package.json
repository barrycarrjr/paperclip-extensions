{
  "name": "paperclip-plugin-gbp-reviews",
  "version": "0.1.0",
  "description": "Google Business Profile review management — parse notification emails, draft AI replies, post via GBP API, and surface a review dashboard.",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "grant": "tsx scripts/grant.ts"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "^2026.427.0",
    "google-auth-library": "^9.15.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "esbuild": "^0.27.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "author": "Barry Carr"
}
