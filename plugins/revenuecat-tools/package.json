{
  "name": "paperclip-plugin-revenuecat-tools",
  "version": "0.2.1",
  "description": "Paperclip plugin that exposes RevenueCat subscriber/entitlement data as agent tools. Multi-project, per-project allowedCompanies, mutations gated.",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "^2026.427.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "esbuild": "^0.27.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "author": "Barry Carr & Tony Allard"
}
